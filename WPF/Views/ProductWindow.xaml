<Window x:Class="WPF.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Management System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#f4f6f9">
    
    <Window.Resources>
        <!-- Modern Button Styles -->
        <Style x:Key="HeaderLogoutButton" TargetType="Button">
            <Setter Property="Background" Value="#dc3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#bb2d3b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CrudButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Input Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#ced4da"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#86b7fe"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <Border Grid.Row="0" Background="#0d6efd" VerticalAlignment="Stretch">
            <Grid Margin="20,0">
                <TextBlock Text="Product Management System" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Welcome back, Admin!" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="14"/>
                    <Button x:Name="btnLogout" Command="{Binding LogoutCommand}" Content="Logout" Style="{StaticResource HeaderLogoutButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Product DataGrid -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Product Catalog Directory" FontSize="15" FontWeight="Bold" Foreground="#333" Margin="0,0,0,12"/>

                <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#e3e6ec" BorderThickness="1" Padding="1">
                    <DataGrid x:Name="dgvProducts"
                               ItemsSource="{Binding Products}"
                               SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               SelectionMode="Single"
                               SelectionUnit="FullRow"
                               HeadersVisibility="Column"
                               GridLinesVisibility="Horizontal"
                               HorizontalGridLinesBrush="#f1f3f7"
                               Background="White"
                               BorderThickness="0"
                               RowBackground="White"
                               AlternatingRowBackground="#f9fafc"
                               FontSize="13"
                               RowHeaderWidth="0">
                        <DataGrid.Resources>
                            <!-- Styled column header -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#f1f3f7"/>
                                <Setter Property="Foreground" Value="#495057"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#dee2e6"/>
                            </Style>
                            <!-- Styled row selection -->
                            <Style TargetType="DataGridRow">
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#e7f1ff"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#084298"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#e7f1ff"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#084298"/>
                                </Style.Resources>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Visibility="Collapsed"/>
                            <DataGridTextColumn Header="Product Code" Binding="{Binding ProductCode}" Width="120"/>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:N0}}" Width="100"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80"/>
                            <DataGridTextColumn Header="Created Date" Binding="{Binding CreatedDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="Created By" Binding="{Binding CreatedBy}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Right side: Edit form -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#e3e6ec" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Product Record Editor" FontSize="15" FontWeight="Bold" Foreground="#333" Margin="0,0,0,18"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <!-- Product Code -->
                        <TextBlock Text="Product Code" FontSize="12" FontWeight="SemiBold" Foreground="#6c757d" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtProductCode" Text="{Binding ProductForm.ProductCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <!-- Product Name -->
                        <TextBlock Text="Product Name" FontSize="12" FontWeight="SemiBold" Foreground="#6c757d" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtProductName" Text="{Binding ProductForm.ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <!-- Price -->
                        <TextBlock Text="Price" FontSize="12" FontWeight="SemiBold" Foreground="#6c757d" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPrice" Text="{Binding ProductForm.PriceText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,15"/>

                        <!-- Quantity -->
                        <TextBlock Text="Quantity" FontSize="12" FontWeight="SemiBold" Foreground="#6c757d" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtQuantity" Text="{Binding ProductForm.QuantityText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,20"/>
                    </StackPanel>

                    <!-- Buttons Panel -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnAdd" Command="{Binding AddCommand}" Grid.Column="0" Content="Add New" Style="{StaticResource CrudButton}" Background="#198754"/>
                        <Button x:Name="btnUpdate" Command="{Binding UpdateCommand}" Grid.Column="1" Content="Update" Style="{StaticResource CrudButton}" Background="#0dcaf0" Foreground="#212529"/>
                        <Button x:Name="btnDelete" Command="{Binding DeleteCommand}" Grid.Column="2" Content="Delete" Style="{StaticResource CrudButton}" Background="#dc3545" Margin="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Footer -->
        <Border Grid.Row="2" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <TextBlock x:Name="lblInfo" Text="{Binding StatusMessage}" Foreground="{Binding StatusColor}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
